# Copy this file to .env and fill in the actual values before deploying.
# .env is gitignored and will not be committed.

# The public/private IP of the VM where infrastructure (Postgres, Kafka) runs
VM_HOST_IP=<your-vm-ip>

# CIDR for the network policy (usually VM_HOST_IP/32)
VM_HOST_CIDR=<your-vm-ip>/32

# Hostname for ingress routing (used to separate UAT/PROD on same cluster)
INGRESS_HOST=<your-hostname>
