<clickhouse>
    <!-- Single source of truth for the Kafka connection used by the schema/02 Kafka-engine tables.
         The broker is read from the KAFKA_BOOTSTRAP_SERVERS environment variable (set on the
         ClickHouse container in docker-compose.yml, which in turn comes from .env) — so the broker
         address is configured in exactly ONE place and shared with the Debezium worker.

         The Kafka tables reference this as `ENGINE = Kafka(cce_kafka)` and only specify the
         per-table topic / consumer group / format. Add SASL/TLS settings here too if the platform
         Kafka requires them, e.g.:
             <security_protocol from_env="KAFKA_SECURITY_PROTOCOL"/>
             <sasl_mechanism from_env="KAFKA_SASL_MECHANISM"/>
             <sasl_username from_env="KAFKA_SASL_USERNAME"/>
             <sasl_password from_env="KAFKA_SASL_PASSWORD"/>
    -->
    <named_collections>
        <cce_kafka>
            <kafka_broker_list from_env="KAFKA_BOOTSTRAP_SERVERS">kafka:9092</kafka_broker_list>
        </cce_kafka>
    </named_collections>
</clickhouse>
